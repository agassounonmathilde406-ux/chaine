<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Empire - Diplomatie & Factions</title>
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #121214;
            color: #ffffff;
            margin: 0;
            padding: 15px;
            text-align: center;
        }
        h2 { color: #f39c12; margin-bottom: 5px; }
        .tabs {
            display: flex;
            justify-content: center;
            margin-bottom: 20px;
            background: #1e1e24;
            border-radius: 8px;
            padding: 5px;
        }
        .tab-btn {
            flex: 1;
            padding: 10px;
            background: none;
            border: none;
            color: #aaa;
            font-weight: bold;
            cursor: pointer;
            border-radius: 6px;
        }
        .tab-btn.active {
            background: #f39c12;
            color: #121214;
        }
        .pane { display: none; }
        .pane.active { display: block; }
        .card {
            background: #1e1e24;
            border-radius: 10px;
            padding: 15px;
            margin-bottom: 12px;
            text-align: left;
            border-left: 5px solid #2ecc71;
            display: flex;
            justify-content: space-between;
            align-items: center;
            transition: 0.2s;
        }
        .card.blackout { border-left-color: #e74c3c; opacity: 0.6; }
        .card.en_guerre { border-left-color: #3498db; opacity: 0.6; }
        .guild-info h3 { margin: 0 0 5px 0; color: #fff; }
        .guild-info p { margin: 0; font-size: 13px; color: #aaa; }
        .badge {
            padding: 5px 10px;
            border-radius: 5px;
            font-size: 11px;
            font-weight: bold;
        }
        .badge.libre { background: #2ecc71; color: #fff; }
        .badge.blackout { background: #e74c3c; color: #fff; }
        .badge.en_guerre { background: #3498db; color: #fff; }
        .btn-action {
            background: #f39c12;
            border: none;
            padding: 8px 15px;
            color: #000;
            font-weight: bold;
            border-radius: 5px;
            cursor: pointer;
        }
        .btn-action:disabled {
            background: #444;
            color: #888;
            cursor: not-allowed;
        }
        table { width: 100%; border-collapse: collapse; margin-top: 10px; background: #1e1e24; border-radius: 8px; overflow: hidden; }
        th, td { padding: 12px; text-align: left; border-bottom: 1px solid #2d2d35; }
        th { background: #2d2d35; color: #f39c12; }
    </style>
</head>
<body>

    <h2>🏛️ PANNEAU STRATÉGIQUE</h2>
    <p id="welcome-msg" style="color: #aaa; font-size: 14px; margin-top: 0;"></p>

    <div class="tabs">
        <button class="tab-btn active" onclick="switchTab('diplomatie')">⚔️ Déclarer la Guerre</button>
        <button class="tab-btn" onclick="switchTab('ranking')">🏆 Top Guildes</button>
    </div>

    <div id="diplomatie" class="pane active">
        <div id="guilds-container">Chargement des renseignements impériaux...</div>
    </div>

    <div id="ranking" class="pane">
        <table>
            <thead>
                <tr>
                    <th>Rang</th>
                    <th>Guilde</th>
                    <th>Pts</th>
                    <th>V/D</th>
                </tr>
            </thead>
            <tbody id="ranking-container">
                </tbody>
        </table>
    </div>

    <script>
        // Initialisation du SDK Telegram Mini App
        const tg = window.Telegram.WebApp;
        tg.ready();
        tg.expand(); // Plein écran

        // Récupération des paramètres envoyés par le bot via l'URL
        const urlParams = new URLSearchParams(window.location.search);
        const monIdGuilde = urlParams.get('my_guild_id');
        const estChef = urlParams.get('is_chef') === 'true';

        document.getElementById('welcome-msg').innerText = estChef ? "Statut : Commandant en Chef" : "Statut : Observateur Militaire";

        // DONNÉES SIMULÉES (En production, ces données proviennent de votre serveur Flask via fetch)
        // Le bot Python va injecter ou envoyer ces structures à la page
        const guildesMock = {
            "G_01": { guild_name: "L'Ordre Noir", status: "NORMAL", en_guerre: false, level: 5 },
            "G_02": { guild_name: "Fairy Tail", status: "BLACKOUT", en_guerre: false, level: 3 },
            "G_03": { guild_name: "Akatsuki", status: "NORMAL", en_guerre: true, level: 8 },
            "G_04": { guild_name: "Espada Faction", status: "NORMAL", en_guerre: false, level: 4 }
        };

        const classementMock = [
            { guild_name: "Akatsuki", points: 240, v: 24, d: 2 },
            { guild_name: "L'Ordre Noir", points: 120, v: 12, d: 3 },
            { guild_name: "Espada Faction", points: 40, v: 4, d: 6 }
        ];

        // Rendu de la liste des Guildes (Diplomatie)
        function renderGuildes() {
            const container = document.getElementById('guilds-container');
            container.innerHTML = "";

            Object.keys(guildesMock).forEach(id => {
                if (id === monIdGuilde) return; // Ne pas s'auto-attaquer

                const g = guildesMock[id];
                let cssClass = "";
                let statusBadge = '<span class="badge libre">LIBRE</span>';
                let canAttack = estChef;

                if (g.status === "BLACKOUT") {
                    cssClass = "blackout";
                    statusBadge = '<span class="badge blackout">❌ BLACKOUT</span>';
                    canAttack = false;
                } else if (g.en_guerre) {
                    cssClass = "en_guerre";
                    statusBadge = '<span class="badge en_guerre">⚔️ EN GUERRE</span>';
                    canAttack = false;
                }

                const card = document.createElement('div');
                card.className = `card ${cssClass}`;
                card.innerHTML = `
                    <div class="guild-info">
                        <h3>${g.guild_name}</h3>
                        <p>Niveau de puissance : ${g.level} | ${statusBadge}</p>
                    </div>
                    <div>
                        <button class="btn-action" ${canAttack ? '' : 'disabled'} onclick="attaquerGuilde('${id}', '${g.guild_name}')">DÉFIER</button>
                    </div>
                `;
                container.appendChild(card);
            });
        }

        // Rendu du classement
        function renderClassement() {
            const container = document.getElementById('ranking-container');
            container.innerHTML = "";
            classementMock.forEach((g, index) => {
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td><b>#${index + 1}</b></td>
                    <td>${g.guild_name}</td>
                    <td style="color: #f39c12; font-weight: bold;">${g.points}</td>
                    <td>${g.v}W / ${g.d}L</td>
                `;
                container.appendChild(tr);
            });
        }

        // Action de déclaration de guerre
        function attaquerGuilde(idCible, nomCible) {
            if (!confirm(`Confirmez-vous la déclaration de guerre contre la guilde : ${nomCible} ?`)) return;

            // Envoi des données de la Mini App vers le bot Telegram en direct
            const resultData = JSON.stringify({
                action: "declarer_guerre",
                cible_id: idCible,
                cible_name: nomCible
            });

            tg.sendData(resultData); // Envoie l'info et ferme automatiquement la Mini App
        }

        function switchTab(tabId) {
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
            document.querySelectorAll('.pane').forEach(p => p.classList.remove('active'));
            event.target.classList.add('active');
            document.getElementById(tabId).classList.add('active');
        }

        // Lancement initial
        renderGuildes();
        renderClassement();
    </script>
</body>
</html>
